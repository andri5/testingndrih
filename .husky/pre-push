#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

branch=$(git branch --show-current)

# semantic-release pushes chore(release) commits to main — rebase before push
if [ "$branch" = "main" ]; then
  git fetch origin main 2>/dev/null || exit 0

  if git rev-parse origin/main >/dev/null 2>&1; then
    behind=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo 0)
    if [ "$behind" -gt 0 ]; then
      echo "main is ${behind} commit(s) behind origin/main — rebasing before push..."
      git pull --rebase origin main || {
        echo "Rebase failed. Fix conflicts, then: git rebase --continue"
        exit 1
      }
    fi
  fi
fi

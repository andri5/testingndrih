{
  "name": "testingndrih-backend",
  "version": "1.0.0",
  "description": "Automated Web Testing Platform - Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build step for Node.js'",
    "test": "jest --coverage --json --outputFile=test-results.json",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --json --outputFile=coverage/test-results.json",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "lint": "eslint src --fix",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "migrate:dev": "dotenv -e .env -- npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:reset": "npx prisma migrate reset --force",
    "migrate:test": "dotenv -e .env.test -- npx prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:seed": "node scripts/seed.js"
  },
  "keywords": [
    "testing",
    "automation",
    "api",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.7.1",
    "archiver": "6.0.1",
    "axios": "1.6.2",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "csv-parse": "5.5.0",
    "csv-parser": "^3.2.0",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.0",
    "multer": "1.4.5-lts.1",
    "openai": "4.26.0",
    "pdf-parse": "1.1.1",
    "playwright": "1.40.0",
    "winston": "3.11.0",
    "ws": "8.15.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/jest": "^29.5.11",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^5.8.0"
  }
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum ExecutionStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
}

enum StepType {
  NAVIGATE
  CLICK
  FILL
  SCREENSHOT
  WAIT
  ASSERTION
  API_CALL
  HOVER
  SCROLL
  FILE_UPLOAD
  DRAG
  MOCK_ROUTE
}

enum ApiMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
  HEAD
}

enum IssueStatus {
  OPEN
  CLOSED
  IN_PROGRESS
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserRole {
  ADMIN
  USER
}

// MODELS
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  menuPermissions String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Password reset fields
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  scenarios        Scenario[]
  executions       Execution[]
  executionLogs    ExecutionLog[]
  testChains       TestChain[]
  chainExecutions  ChainExecution[]
  testSchedules    TestSchedule[] @relation("UserSchedules")
  executionBatches ExecutionBatch[] @relation("UserBatches")
  matrixExecutions MatrixExecution[] @relation("UserMatrices")
  securityScans    SecurityScan[]
  apiTokens              ApiToken[]
  notificationSettings   NotificationSettings?
  testEnvironments       TestEnvironment[]
  visualBaselines        VisualBaseline[]
  visualComparisons      VisualComparison[]

  @@map("users")
}

model LandingFeedback {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  message   String
  page      String?
  lang      String?  @default("id")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("landing_feedback")
}

model SitePageView {
  id        String   @id @default(cuid())
  path      String
  lang      String?
  visitorId String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([visitorId])
  @@map("site_page_views")
}

model TestEnvironment {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  baseUrl     String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  variables EnvironmentVariable[]

  @@unique([userId, name])
  @@index([userId])
  @@map("test_environments")
}

model EnvironmentVariable {
  id            String   @id @default(cuid())
  environmentId String
  key           String
  value         String
  isSecret      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment TestEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, key])
  @@index([environmentId])
  @@map("environment_variables")
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_tokens")
}

model NotificationSettings {
  userId             String   @id
  emailOnFailure       Boolean  @default(true)
  emailOnSmokeFail     Boolean  @default(true)
  webhookUrl           String?
  webhookEnabled       Boolean  @default(false)
  webhookOnFailure     Boolean  @default(true)
  webhookOnSmokeFail   Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Scenario {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String
  steps       Int      @default(0) // count of test steps
  isSmoke     Boolean  @default(false) // Mark scenario as smoke test
  isStress    Boolean  @default(false) // Mark scenario as stress test
  isSecurity  Boolean  @default(false) // Mark scenario as security test
  isFavorite  Boolean  @default(false)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testSteps     TestStep[]
  executions    Execution[]
  apiTests      ApiTest[]
  chainSteps    ChainStep[]
  testSchedules TestSchedule[] @relation("ScenarioSchedules")
  matrixExecutions MatrixExecution[] @relation("ScenarioMatrices")
  securityScans SecurityScan[]
  visualBaselines VisualBaseline[]
  visualComparisons VisualComparison[]

  @@index([userId])
  @@index([isStress])
  @@index([isSecurity])
  @@map("scenarios")
}

model VisualBaseline {
  id         String   @id @default(cuid())
  userId     String
  scenarioId String
  stepNumber Int
  browser    String   @default("chromium")
  imagePath  String
  width      Int?
  height     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, stepNumber, browser])
  @@index([userId])
  @@index([scenarioId])
  @@map("visual_baselines")
}

model VisualComparison {
  id           String   @id @default(cuid())
  userId       String
  scenarioId   String
  executionId  String?
  stepNumber   Int
  browser      String   @default("chromium")
  baselinePath String
  currentPath  String
  diffPath     String?
  diffPercent  Float    @default(0)
  diffPixels   Int      @default(0)
  totalPixels  Int      @default(0)
  status       String   @default("FAILED")
  threshold    Float    @default(0.1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scenarioId])
  @@index([executionId])
  @@index([status])
  @@map("visual_comparisons")
}

model TestStep {
  id         String   @id @default(cuid())
  stepNumber Int
  type       StepType
  description String
  selector   String? // CSS selector or XPath for UI interactions
  value      String? // Input value or assertion text
  metadata   String? // JSON string for additional data
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  scenarioId String

  scenario   Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  stepResults StepResult[]

  @@unique([scenarioId, stepNumber])
  @@index([scenarioId])
  @@map("test_steps")
}

model Execution {
  id                  String            @id @default(cuid())
  status              ExecutionStatus   @default(PENDING)
  startTime           DateTime?
  endTime             DateTime?
  duration            Int? // in milliseconds
  errorMessage        String?
  passedSteps         Int               @default(0)
  failedSteps         Int               @default(0)
  totalSteps          Int
  videoPath           String?           // path to execution video file
  browser             String?           @default("chromium") // chromium | firefox | webkit
  headless            Boolean?          @default(false)
  testType            String?           @default("STANDARD") // STANDARD | SMOKE | STRESS | SECURITY
  isSmokeTest         Boolean?          @default(false) // Mark as smoke test execution
  isStressTest        Boolean?          @default(false) // Mark as stress test execution
  stressProfile       String?           // light | medium | heavy | extreme
  concurrencyLevel    Int?              @default(1) // Number of parallel test instances
  iterationCount      Int?              @default(1) // How many times to repeat the test
  executionBatchId    String?           // for parallel execution batches
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  userId              String
  scenarioId          String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario     Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  batch        ExecutionBatch? @relation(fields: [executionBatchId], references: [id], onDelete: SetNull)
  stepResults  StepResult[]
  screenshots  Screenshot[]
  issues       Issue[]
  executionLogs ExecutionLog[]
  stressMetrics StressMetrics?

  @@index([userId])
  @@index([scenarioId])
  @@index([status])
  @@index([testType])
  @@index([executionBatchId])
  @@index([stressProfile])
  @@map("executions")
}

model StepResult {
  id           String            @id @default(cuid())
  status       ExecutionStatus
  errorMessage String?
  duration     Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  executionId  String
  testStepId   String

  execution  Execution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  testStep   TestStep   @relation(fields: [testStepId], references: [id], onDelete: Cascade)
  screenshot Screenshot?

  @@index([executionId])
  @@index([testStepId])
  @@map("step_results")
}

model Screenshot {
  id           String   @id @default(cuid())
  url          String
  timestamp    DateTime @default(now())
  executionId  String
  stepResultId String   @unique

  execution   Execution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepResult  StepResult  @relation(fields: [stepResultId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("screenshots")
}

model ApiTest {
  id          String   @id @default(cuid())
  name        String
  description String?
  method      ApiMethod
  url         String
  headers     String? // JSON string
  body        String? // JSON string
  expectedCode Int           @default(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  scenarioId  String

  scenario    Scenario        @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  results     ApiTestResult[]

  @@index([scenarioId])
  @@map("api_tests")
}

model ApiTestResult {
  id           String   @id @default(cuid())
  status       Int
  responseTime Int       // in milliseconds
  response     String?   // JSON string
  passed       Boolean
  errorMessage String?
  createdAt    DateTime @default(now())
  apiTestId    String

  apiTest  ApiTest @relation(fields: [apiTestId], references: [id], onDelete: Cascade)

  @@index([apiTestId])
  @@map("api_test_results")
}

model Issue {
  id        String          @id @default(cuid())
  title     String
  description String?
  status    IssueStatus     @default(OPEN)
  severity  IssueSeverity   @default(MEDIUM)
  stepNumber Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  executionId String

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("issues")
}

model ExecutionLog {
  id        String   @id @default(cuid())
  level     String   // INFO, WARN, ERROR, DEBUG
  message   String
  createdAt DateTime @default(now())
  executionId String
  userId    String

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([userId])
  @@map("execution_logs")
}

model TestChain {
  id          String   @id @default(cuid())
  name        String
  description String?
  steps       Int      @default(0) // count of chain steps
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chainSteps        ChainStep[]
  chainExecutions   ChainExecution[]

  @@index([userId])
  @@map("test_chains")
}

model ChainStep {
  id           String  @id @default(cuid())
  stepNumber   Int
  scenarioId   String
  description  String?
  runMode      String  @default("sequential") // sequential, parallel, conditional
  waitTime     Int     @default(0) // milliseconds to wait before next step
  retryCount   Int     @default(1) // times to retry if failed
  stopOnFail   Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chainId      String

  chain        TestChain    @relation(fields: [chainId], references: [id], onDelete: Cascade)
  scenario     Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  stepResults  ChainStepResult[]

  @@unique([chainId, stepNumber])
  @@index([chainId])
  @@index([scenarioId])
  @@map("chain_steps")
}

model ChainExecution {
  id           String            @id @default(cuid())
  status       ExecutionStatus   @default(PENDING)
  startTime    DateTime?
  endTime      DateTime?
  duration     Int? // milliseconds
  totalSteps   Int
  passedSteps  Int @default(0)
  failedSteps  Int @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chainId      String
  userId       String

  chain         TestChain        @relation(fields: [chainId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepResults   ChainStepResult[]

  @@index([chainId])
  @@index([userId])
  @@index([status])
  @@map("chain_executions")
}

model ChainStepResult {
  id           String            @id @default(cuid())
  stepNumber   Int
  status       ExecutionStatus
  duration     Int? // milliseconds
  errorMessage String?
  executionId  String // the individual scenario execution created by this chain step
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chainStepId  String
  chainExecutionId String

  chainStep       ChainStep       @relation(fields: [chainStepId], references: [id], onDelete: Cascade)
  chainExecution  ChainExecution  @relation(fields: [chainExecutionId], references: [id], onDelete: Cascade)

  @@index([chainStepId])
  @@index([chainExecutionId])
  @@map("chain_step_results")
}

model TestSchedule {
  id                String   @id @default(cuid())
  userId            String
  scenarioId        String
  frequency         String
  timeOfDay         String?
  daysOfWeek        String?
  cronExpression    String?
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  lastExecutionId   String?
  successCount      Int      @default(0)
  failureCount      Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User     @relation("UserSchedules", fields: [userId], references: [id], onDelete: Cascade)
  scenario          Scenario @relation("ScenarioSchedules", fields: [scenarioId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([scenarioId])
  @@index([isActive])
  @@map("test_schedules")
}

model ExecutionBatch {
  id            String   @id @default(cuid())
  status        String   @default("RUNNING") // RUNNING, SUCCESS, PARTIAL_FAILURE, FAILED, CANCELLED
  scenarioCount Int
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  startedAt     DateTime
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  userId        String

  user       User        @relation("UserBatches", fields: [userId], references: [id], onDelete: Cascade)
  executions Execution[]

  @@index([userId])
  @@index([status])
  @@map("execution_batches")
}

model MatrixExecution {
  id        String   @id @default(cuid())
  status    String   @default("RUNNING") // RUNNING, SUCCESS, PARTIAL_FAILURE, FAILED
  browsers  String[] // array of browser names: ["chromium", "firefox", "webkit"]
  results   String?  // JSON string with compatibility matrix
  startedAt DateTime
  completedAt DateTime?
  createdAt DateTime @default(now())
  scenarioId String
  userId    String

  user     User     @relation("UserMatrices", fields: [userId], references: [id], onDelete: Cascade)
  scenario Scenario @relation("ScenarioMatrices", fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scenarioId])
  @@index([status])
  @@map("matrix_executions")
}

model StressMetrics {
  id                String   @id @default(cuid())
  executionId       String   @unique
  // Response times (in milliseconds)
  responseTimeMin   Int      @default(0)
  responseTimeAvg   Int      @default(0)
  responseTimeMax   Int      @default(0)
  responseTimeP50   Int      @default(0) // 50th percentile
  responseTimeP95   Int      @default(0) // 95th percentile
  responseTimeP99   Int      @default(0) // 99th percentile
  // Performance metrics
  throughput        Float    @default(0) // requests per second
  errorRate         Float    @default(0) // percentage of failed steps
  failedStepsCount  Int      @default(0)
  passedStepsCount  Int      @default(0)
  totalStepsCount   Int      @default(0)
  // Resource usage
  cpuUsagePercent   Float?   @default(0)
  memoryUsageMB     Float?   @default(0)
  // Test configuration echo
  concurrency       Int      @default(1)
  iterations        Int      @default(1)
  duration          Int      // total test duration in milliseconds
  createdAt         DateTime @default(now())

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("stress_metrics")
}

model SecurityScan {
  id                 String   @id @default(cuid())
  scenarioId         String
  executionId        String?  // linked execution
  
  // Scan metadata
  scanType           String   @default("full") // "full" | "quick" | "custom"
  vulnTypesTargeted  String[] @default([]) // array of vulnerability types
  status             String   @default("PENDING") // PENDING|RUNNING|COMPLETED|FAILED
  startedAt          DateTime?
  completedAt        DateTime?
  duration           Int?     // milliseconds
  
  // Results summary
  findingsCount      Int      @default(0)
  criticalCount      Int      @default(0)
  highCount          Int      @default(0)
  mediumCount        Int      @default(0)
  lowCount           Int      @default(0)
  infoCount          Int      @default(0)
  
  riskScore          Float    @default(0) // 0-100 overall risk
  
  // Timestamps
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userId             String
  
  // Relations
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario           Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  findings           SecurityFinding[]
  
  @@index([userId])
  @@index([scenarioId])
  @@index([status])
  @@index([riskScore])
  @@map("security_scans")
}

model SecurityFinding {
  id                 String   @id @default(cuid())
  scanId             String
  
  // Vulnerability details
  type               String   // SQL_INJECTION, XSS_STORED, etc
  severity           String   // CRITICAL | HIGH | MEDIUM | LOW | INFO
  cvssScore          Float    // 0-10
  cvssVector         String?  // CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H
  
  // Finding information
  title              String
  description        String
  affectedUrl        String?
  affectedParameter  String?
  
  // Evidence & proof
  payload            String?  // attack payload used
  evidenceRequest    String?  // HTTP request details
  evidenceResponse   String?  // HTTP response snippet
  
  // Remediation
  remediationNotes   String?  // how to fix
  owasp10Category    String?  // A01:2021, A02:2021, etc
  cveId              String?  // if known CVE
  
  // Status tracking
  status             String   @default("NEW") // NEW|ACKNOWLEDGED|FIXED|FALSE_POSITIVE
  confirmedAt        DateTime?
  fixedAt            DateTime?
  notes              String?
  
  // Timestamps
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  // Relations
  scan               SecurityScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  
  @@index([scanId])
  @@index([severity])
  @@index([type])
  @@index([cvssScore])
  @@map("security_findings")
}

model SecurityPayload {
  id                 String   @id @default(cuid())
  
  // Payload metadata
  type               String   // SQL_INJECTION, XSS, COMMAND_INJECTION, etc
  severity           String   // CRITICAL | HIGH | MEDIUM
  
  // Payload definition
  name               String
  description        String
  payloadContent     String   // actual attack payload
  targetParameter    String   // "query", "body", "header", "path"
  
  // Detection
  detectionPattern   String?  // regex to detect success
  expectedIndicators String[] @default([]) // array of success indicators
  
  // Safety
  isDangerous        Boolean  @default(false) // requires confirmation
  category           String   // "injection", "xss", "auth", "api", etc
  
  // Metadata
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@index([type])
  @@index([category])
  @@map("security_payloads")
}

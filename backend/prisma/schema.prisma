// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum ExecutionStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
}

enum StepType {
  NAVIGATE
  CLICK
  FILL
  SCREENSHOT
  WAIT
  ASSERTION
  API_CALL
}

enum ApiMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
  HEAD
}

enum IssueStatus {
  OPEN
  CLOSED
  IN_PROGRESS
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// MODELS
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scenarios        Scenario[]
  executions       Execution[]
  executionLogs    ExecutionLog[]
  qaseIntegration  QaseIntegration?

  @@map("users")
}

model Scenario {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String
  steps       Int      @default(0) // count of test steps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testSteps  TestStep[]
  executions Execution[]
  apiTests   ApiTest[]
  qaseTestCases QaseTestCase[]

  @@index([userId])
  @@map("scenarios")
}

model TestStep {
  id         String   @id @default(cuid())
  stepNumber Int
  type       StepType
  description String
  selector   String? // CSS selector or XPath for UI interactions
  value      String? // Input value or assertion text
  metadata   String? // JSON string for additional data
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  scenarioId String

  scenario   Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  stepResults StepResult[]

  @@unique([scenarioId, stepNumber])
  @@index([scenarioId])
  @@map("test_steps")
}

model Execution {
  id           String            @id @default(cuid())
  status       ExecutionStatus   @default(PENDING)
  startTime    DateTime?
  endTime      DateTime?
  duration     Int? // in milliseconds
  errorMessage String?
  passedSteps  Int               @default(0)
  failedSteps  Int               @default(0)
  totalSteps   Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  userId       String
  scenarioId   String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario     Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  stepResults  StepResult[]
  screenshots  Screenshot[]
  issues       Issue[]
  executionLogs ExecutionLog[]

  @@index([userId])
  @@index([scenarioId])
  @@index([status])
  @@map("executions")
}

model StepResult {
  id           String            @id @default(cuid())
  status       ExecutionStatus
  errorMessage String?
  duration     Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  executionId  String
  testStepId   String

  execution  Execution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  testStep   TestStep   @relation(fields: [testStepId], references: [id], onDelete: Cascade)
  screenshot Screenshot?

  @@index([executionId])
  @@index([testStepId])
  @@map("step_results")
}

model Screenshot {
  id           String   @id @default(cuid())
  url          String
  timestamp    DateTime @default(now())
  executionId  String
  stepResultId String   @unique

  execution   Execution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepResult  StepResult  @relation(fields: [stepResultId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("screenshots")
}

model ApiTest {
  id          String   @id @default(cuid())
  name        String
  description String?
  method      ApiMethod
  url         String
  headers     String? // JSON string
  body        String? // JSON string
  expectedCode Int           @default(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  scenarioId  String

  scenario    Scenario        @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  results     ApiTestResult[]

  @@index([scenarioId])
  @@map("api_tests")
}

model ApiTestResult {
  id           String   @id @default(cuid())
  status       Int
  responseTime Int       // in milliseconds
  response     String?   // JSON string
  passed       Boolean
  errorMessage String?
  createdAt    DateTime @default(now())
  apiTestId    String

  apiTest  ApiTest @relation(fields: [apiTestId], references: [id], onDelete: Cascade)

  @@index([apiTestId])
  @@map("api_test_results")
}

model Issue {
  id        String          @id @default(cuid())
  title     String
  description String?
  status    IssueStatus     @default(OPEN)
  severity  IssueSeverity   @default(MEDIUM)
  stepNumber Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  executionId String

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("issues")
}

model ExecutionLog {
  id        String   @id @default(cuid())
  level     String   // INFO, WARN, ERROR, DEBUG
  message   String
  createdAt DateTime @default(now())
  executionId String
  userId    String

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([userId])
  @@map("execution_logs")
}

model QaseIntegration {
  id           String   @id @default(cuid())
  userId       String   @unique
  apiKey       String   // Ideally encrypted - see TODO below
  projectCode  String
  isConnected  Boolean  @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testCases QaseTestCase[]

  @@index([userId])
  @@map("qase_integrations")
}

model QaseTestCase {
  id              String   @id @default(cuid())
  userId          String
  qaseId          Int      // ID from Qase API
  caseTitle       String
  caseDescription String?
  qaseStatus      String   // Status from Qase (e.g., 'active', 'draft')
  scenarioId      String?  // Link to created scenario (optional)
  tags            String?  // JSON array string
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  integration QaseIntegration @relation(fields: [userId], references: [userId], onDelete: Cascade)
  scenario    Scenario?       @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  @@unique([qaseId, userId])
  @@index([userId])
  @@index([scenarioId])
  @@map("qase_test_cases")
}

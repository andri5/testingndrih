# ================================================================================
# Local development — copy to backend/.env
# Same application code as production; only these values differ per environment.
# ================================================================================

# ─── Database (local PostgreSQL or Docker postgres on 5432) ─────────────────
DATABASE_URL=postgresql://testingndrih_user:your_password@127.0.0.1:5432/testingndrih?sslmode=disable
DATABASE_TEST_URL=postgresql://testingndrih_user:your_password@127.0.0.1:5432/testingndrih_test

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me-min-32-characters-long
JWT_EXPIRES_IN=7d

# ─── Application ─────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# Link in password-reset emails (Vite dev server)
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# ─── Gmail SMTP (local dev account) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=faizalandri04@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=Test Sambil Ngopi Dev <faizalandri04@gmail.com>

# ─── Captcha (required for Turnstile on login, register, reset-password) ─────
# Site key is public; secret key from Cloudflare dashboard (same widget as prod)
TURNSTILE_SITE_KEY=0x4AAAAAADhwESXxd2ogun4g
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Production VPS uses the same variable names — see docs/DEPLOYMENT.md:
#   FRONTEND_URL=https://testsambilngopi.com
#   SMTP_USER=testsambilngopi@gmail.com
#   SMTP_FROM=Test Sambil Ngopi <testsambilngopi@gmail.com>

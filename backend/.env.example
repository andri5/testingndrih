# ================================================================================
# Local development — copy to backend/.env
# NEVER commit this file with real passwords or personal emails
# ================================================================================

DATABASE_URL=postgresql://testingndrih_user:YOUR_PASSWORD@127.0.0.1:5432/testingndrih?sslmode=disable
DATABASE_TEST_URL=postgresql://testingndrih_user:YOUR_PASSWORD@127.0.0.1:5432/testingndrih_test

JWT_SECRET=dev-secret-change-me-min-32-characters-long
JWT_EXPIRES_IN=7d

PORT=5001
NODE_ENV=development

# Platform admin (always receives ADMIN role) — use your own email locally
ADMIN_EMAIL=admin@example.com

FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM="Test Sambil Ngopi Dev <your-email@gmail.com>"

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Production VPS: set real values only in server .env — see docs/DEPLOYMENT.md

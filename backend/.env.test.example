# Copy to backend/.env.test for isolated integration/database tests
# Create DB first: createdb testingndrih_test (or via Docker)

DATABASE_URL=postgresql://testingndrih_user:your_password@127.0.0.1:5432/testingndrih_test?sslmode=disable
DATABASE_TEST_URL=postgresql://testingndrih_user:your_password@127.0.0.1:5432/testingndrih_test?sslmode=disable
JWT_SECRET=test-jwt-secret-min-32-characters-long
NODE_ENV=test

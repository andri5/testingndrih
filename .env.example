# ================================================================================
# TestingNDRIH - Environment Configuration
# Copy this file to .env and fill in YOUR values before running
# ================================================================================

# ─── Database Configuration ─────────────────────────────────────────────────
# For Docker setup:
#   - Internal connection (from app container to postgres container):
#     DATABASE_URL=postgresql://testingndrih_user:testpass123@postgres:5432/testingndrih
#   - External connection (from laptop 2 to laptop 1):
#     DATABASE_URL=postgresql://testingndrih_user:testpass123@LAPTOP_1_IP:5432/testingndrih

DB_USER=testingndrih_user
DB_PASSWORD=testpass123
DB_NAME=testingndrih
DB_PORT=5432

# Docker: use 'postgres' as hostname (internal container network)
# Manual setup or multi-laptop: use localhost or IP address
DATABASE_URL=postgresql://testingndrih_user:testpass123@postgres:5432/testingndrih

# Test Database
DATABASE_TEST_URL=postgresql://testingndrih_user:testpass123@postgres:5432/testingndrih_test

# ─── JWT & Security ────────────────────────────────────────────────────────
# Generate a long random string for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-long-random-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Encrypt secret environment variables at rest (32+ chars recommended)
ENCRYPTION_KEY=your-encryption-key-change-in-production-min-32-chars

# ─── Application ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Vite dev server (npm run dev in frontend/)
FRONTEND_URL=http://localhost:3001

# Docker full stack (single port 3000):
# FRONTEND_URL=http://localhost:3000

# Production:
# FRONTEND_URL=https://testsambilngopi.com

# ─── File Upload ────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
SCREENSHOT_DIR=./uploads/screenshots
VIDEO_DIR=./uploads/videos
LOG_DIR=./logs

# ─── CORS ───────────────────────────────────────────────────────────────────
# For Docker: http://localhost:3000 (same container on port 3000)
# For multi-laptop setup: http://LAPTOP_IP:3000
CORS_ORIGIN=http://localhost:3000

# ─── Seed User ──────────────────────────────────────────────────────────────
# Docker: seed runs on container start only when RUN_SEED=true
# Production: set true once for first deploy, then false for all redeploys
RUN_SEED=false
SEED_EMAIL=admin@testingndrih.local
SEED_PASSWORD=changeme123

# ─── Email Service (Gmail SMTP) ─────────────────────────────────────────────
# Create App Password: Google Account → Security → 2-Step Verification → App passwords
#
# Local development:
# SMTP_USER=faizalandri04@gmail.com
# SMTP_FROM="Test Sambil Ngopi Dev <faizalandri04@gmail.com>"
#
# Production (VPS .env):
# SMTP_USER=testsambilngopi@gmail.com
# SMTP_FROM="Test Sambil Ngopi <testsambilngopi@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="Test Sambil Ngopi <your-email@gmail.com>"

# ─── Notifications (optional) ───────────────────────────────────────────────
# Configure SMTP above for email alerts on test failures.
# Webhook URL can be set per-user in Settings → Integrations (Slack, Discord, etc.)

# ─── Scheduler ──────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true

# ─── Captcha (Cloudflare Turnstile — free) ─────────────────────────────────
# Create keys: https://dash.cloudflare.com → Turnstile → Add site
# Frontend build-time + backend runtime (same site key value)
# Domain in Cloudflare Turnstile widget must include testsambilngopi.com
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Browser ────────────────────────────────────────────────────────────────
# For Playwright test execution
BROWSER_HEADLESS=false
BROWSER_SLOWMO=300

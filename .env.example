# ================================================================================
# TestingNDRIH - Environment Configuration
# Copy this file to .env and fill in YOUR values before running
# NEVER commit .env or real passwords to git
# ================================================================================

# ─── Database Configuration ─────────────────────────────────────────────────
# For Docker setup:
#   - Internal connection (from app container to postgres container):
#     DATABASE_URL=postgresql://testingndrih_user:YOUR_DB_PASSWORD@postgres:5432/testingndrih
#   - External connection (from laptop 2 to laptop 1):
#     DATABASE_URL=postgresql://testingndrih_user:YOUR_DB_PASSWORD@LAPTOP_1_IP:5432/testingndrih

DB_USER=testingndrih_user
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=testingndrih
DB_PORT=5432

DATABASE_URL=postgresql://testingndrih_user:YOUR_DB_PASSWORD@postgres:5432/testingndrih
DATABASE_TEST_URL=postgresql://testingndrih_user:YOUR_DB_PASSWORD@postgres:5432/testingndrih_test

# ─── JWT & Security ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-long-random-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=your-encryption-key-change-in-production-min-32-chars

# Platform admin (receives ADMIN role) — set your own email, never commit real values
ADMIN_EMAIL=admin@example.com

# ─── Application ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Production example (set in VPS .env only):
# FRONTEND_URL=https://your-domain.com
# CORS_ORIGIN=https://your-domain.com

# ─── File Upload ────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
SCREENSHOT_DIR=./uploads/screenshots
VIDEO_DIR=./uploads/videos
LOG_DIR=./logs

CORS_ORIGIN=http://localhost:3000

# ─── Seed User (first run only) ─────────────────────────────────────────────
RUN_SEED=false
SEED_EMAIL=admin@testingndrih.local
SEED_PASSWORD=change-me-before-first-run

# ─── Email Service (Gmail SMTP) ─────────────────────────────────────────────
# Create App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="Test Sambil Ngopi <your-email@gmail.com>"

# ─── Notifications (optional) ───────────────────────────────────────────────
ENABLE_SCHEDULER=true

# ─── Captcha (Cloudflare Turnstile) ─────────────────────────────────────────
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Browser ────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=false
BROWSER_SLOWMO=300
